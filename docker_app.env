# Postgress settings
DB_HOST=elex_postgres_db
DB_PORT=5432
DB_DATABASE=file_metadata
DB_USERNAME=elex_storage
DB_PASSWORD=pass1234
DB_SCHEMA=public

# Rabbitmq settings
RABBITMQ_HOST=elex_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=elex_storage
RABBITMQ_PASSWORD=pass1234

# FileMetadata settings
FILE_META_DATA_HTTP_PORT=8081
FILE_META_DATA_GRPC_PORT=50053

# api_gateway settings
API_GATEWAY_HTTP_Addr=localhost:8080

# identity_service settings
IDENTITY_SERVICE_Grpc_Addr=0.0.0.0:50051
ACCESS_TOKEN_DURATION=48h
REFRESH_TOKEN_DURATION=720h

# Shared settings
MIGRATIONS_DIR=migrations
LOGGER_PATH=..\..\bin\logs\logs.log